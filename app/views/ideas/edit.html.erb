<%= render "shared/breadcrumbs", items: @breadcrumbs %>

<%= link_to "詳細へ戻る", idea_path(@idea) %>

<h1>アイデア編集</h1>

<% if @idea.errors.any? %>
  <ul>
    <% @idea.errors.full_messages.each do |msg| %>
      <li><%= msg %></li>
    <% end %>
  </ul>
<% end %>

<%= render "form", idea: @idea %>

<div style="margin-top: 32px;">
  <%= link_to "削除", idea_path(@idea),
        data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
        style: "display: inline-block; background: #dc2626; color: #ffffff; border: none; border-radius: 8px; padding: 12px 24px; font-weight: bold; text-decoration: none; cursor: pointer;" %>
</div>
