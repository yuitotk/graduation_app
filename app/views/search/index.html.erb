<!-- app/views/search/index.html.erb -->
<h1 style="color: #c4b5fd;">検索結果</h1>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<% q = @query.to_s %>
<% scope = (@scope.presence || "all").to_s %>
<% breadcrumb_params = (@search_breadcrumb_params || {}).merge(return_to: request.fullpath) %>

<h2 style="color: #c4b5fd;">検索条件</h2>
<ul>
  <li>検索ワード：<%= q.presence || "（未入力）" %></li>
  <li>
    範囲：
    <%= ({ "all" => "すべて", "home" => "ホーム未所属", "story" => "ストーリー内", "event" => "イベント内", "story_event_idea" => "詳細メモ内", "element" => "要素内" }[scope] || "すべて") %>
  </li>
  <li>
    検索対象：
    <% if @within_story && @story.present? %>
      この作品内（<%= @story.title %>）のみ
    <% else %>
      全体アイデア
    <% end %>
  </li>

  <li>
    要素：
    <% if @selected_story_element.present? %>
      <% kind_labels = { "character" => "キャラ", "item" => "アイテム", "setting" => "設定" } %>
      [<%= kind_labels[@selected_story_element.kind.to_s] || @selected_story_element.kind %>]<%= @selected_story_element.marker %>　<%= @selected_story_element.name %>
    <% else %>
      （なし）
    <% end %>
  </li>
</ul>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<% results = (@results || {}).with_indifferent_access %>

<% pair_total = ->(pair) { (pair[:created_here]&.count || 0) + (pair[:moved]&.count || 0) } %>
<% home_total = ->(pair) { (pair[:created_here]&.count || 0) } %>

<% snippet_for = lambda do |text, keyword|
     s = text.to_s
     k = keyword.to_s
     if k.present? && (i = s.index(k))
       left  = [i - 40, 0].max
       right = [i + k.length + 40, s.length].min
       "…#{s[left...right]}…"
     else
       s.length > 160 ? "#{s[0, 160]}…" : s
     end
   end %>

<% idea_image_url_for = lambda do |idea|
     if idea.respond_to?(:image) && idea.image.present?
       idea.image.url
     elsif idea.respond_to?(:idea_image) && idea.idea_image&.image.present?
       idea.idea_image.image.url
     end
   end %>

<% render_idea_card = lambda do |idea|
     idea_image_url = idea_image_url_for.call(idea)
%>
  <%= link_to idea_path(idea, breadcrumb_params),
              style: "display: block; text-decoration: none; color: inherit;" do %>
    <div style="margin: 0 0 12px 0; padding: 16px; border: 2px solid #555555; border-radius: 16px; background: #1e1e1e; color: #f5f5f5;">
      <% if idea.title.present? %>
        <div style="font-weight: bold; margin-bottom: 6px; color: #ddd6fe;"><%= idea.title %></div>
      <% end %>

      <div style="margin-bottom: 12px;">
        <% if idea_image_url.present? %>
          <%= image_tag idea_image_url,
                        style: "display: block; width: 240px; height: 140px; object-fit: cover; border: 2px solid #555555; border-radius: 12px;" %>
        <% else %>
          <div style="display: flex; align-items: center; justify-content: center; width: 240px; height: 140px; border: 2px solid #555555; border-radius: 12px; background: #2a2a2a; color: #f5f5f5;">
            画像なし
          </div>
        <% end %>
      </div>

      <% if idea.memo.present? %>
        <div style="display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; overflow: hidden; white-space: normal; line-height: 1.6; max-height: 4.8em; color: #f5f5f5;">
          <%= simple_format(snippet_for.call(idea.memo, q)) %>
        </div>
      <% else %>
        <div style="color: #dddddd;">本文なし</div>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if q.blank? && @story_element_id.blank? %>
  <p>検索ワードを入力して検索してください。</p>
<% else %>
  <h2 style="color: #c4b5fd;">件数</h2>

  <% if scope == "all" %>
    <ul>
      <li>ホーム未所属: <%= home_total.call(results[:home] || {}) %> 件</li>
      <li>ストーリー内: <%= pair_total.call(results[:story] || {}) %> 件</li>
      <li>イベント内: <%= pair_total.call(results[:event] || {}) %> 件</li>
      <li>詳細メモ内: <%= pair_total.call(results[:story_event_idea] || {}) %> 件</li>
      <li>要素内: <%= pair_total.call(results[:element] || {}) %> 件</li>
    </ul>
  <% else %>
    <% label =
         { "home" => "ホーム未所属", "story" => "ストーリー内", "event" => "イベント内", "story_event_idea" => "詳細メモ内", "element" => "要素内" }[scope] || "すべて" %>

    <% count =
         if scope == "home"
           home_total.call(results[:home] || {})
         else
           pair_total.call(results[scope.to_sym] || {})
         end %>

    <p><strong><%= label %></strong>: <%= count %> 件</p>
  <% end %>

  <hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

  <% render_category = lambda do |title, key, is_home: false|
       pair = results[key] || {}
       created_rel = pair[:created_here] || Idea.none
       moved_rel   = pair[:moved] || Idea.none
  %>
    <section style="margin-bottom: 24px;">
      <h1 style="color: #c4b5fd;"><%= title %></h1>

      <% if is_home %>
        <% if created_rel.count == 0 %>
          <p>該当なし</p>
        <% else %>
          <div style="margin: 16px 0;">
            <% created_rel.limit(50).each do |idea| %>
              <% render_idea_card.call(idea) %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <h2 style="color: #c4b5fd;">新規作成したアイデア</h2>
        <% if created_rel.count == 0 %>
          <p>該当なし</p>
        <% else %>
          <div style="margin: 16px 0;">
            <% created_rel.limit(50).each do |idea| %>
              <% render_idea_card.call(idea) %>
            <% end %>
          </div>
        <% end %>

        <h2 style="color: #c4b5fd;">移動してきたアイデア</h2>
        <% if moved_rel.count == 0 %>
          <p>該当なし</p>
        <% else %>
          <div style="margin: 16px 0;">
            <% moved_rel.limit(50).each do |idea| %>
              <% render_idea_card.call(idea) %>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </section>
  <% end %>

  <% if scope == "all" %>
    <% render_category.call("ホーム未所属", :home, is_home: true) %>
    <% render_category.call("ストーリー内", :story) %>
    <% render_category.call("イベント内", :event) %>
    <% render_category.call("詳細メモ内", :story_event_idea) %>
    <% render_category.call("要素内", :element) %>
  <% elsif scope == "home" %>
    <% render_category.call("ホーム未所属", :home, is_home: true) %>
  <% elsif scope == "story" %>
    <% render_category.call("ストーリー内", :story) %>
  <% elsif scope == "event" %>
    <% render_category.call("イベント内", :event) %>
  <% elsif scope == "story_event_idea" %>
    <% render_category.call("詳細メモ内", :story_event_idea) %>
  <% elsif scope == "element" %>
    <% render_category.call("要素内", :element) %>
  <% end %>
<% end %>
