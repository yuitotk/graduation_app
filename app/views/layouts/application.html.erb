<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "創記録 | AIアイデア作成・要素設定・時系列確認ができる創作支援アプリ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "AI作成で発想を広げ、要素設定と整合性チェックで物語の流れや登場要素を時系列で確認できる創作支援アプリです。" %>">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="創記録">
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : "創記録 | AIアイデア作成・要素設定・時系列確認ができる創作支援アプリ" %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : "AI作成で発想を広げ、要素設定と整合性チェックで物語の流れや登場要素を時系列で確認できる創作支援アプリです。" %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= "#{request.base_url}/ogp.png" %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : "創記録 | AIアイデア作成・要素設定・時系列確認ができる創作支援アプリ" %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : "AI作成で発想を広げ、要素設定と整合性チェックで物語の流れや登場要素を時系列で確認できる創作支援アプリです。" %>">
    <meta name="twitter:image" content="<%= "#{request.base_url}/ogp.png" %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/header" %>

    <p><%= notice %></p>
    <p><%= alert %></p>

    <%= yield %>
  </body>
</html>
