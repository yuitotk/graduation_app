<p><%= link_to "アイデア一覧（ホーム）へ", ideas_path, style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %></p>

<h1 style="color: #c4b5fd;">ストーリー一覧</h1>

<ul style="margin: 8px 0 20px 20px; font-size: 17px; line-height: 1.8;">
  <li>アイデアがまとまってきたら、ストーリーを作成していきましょう。</li>
  <li>作品内でイベントや要素を管理しながら、全体の流れを見やすくできます。</li>
  <li>何回でも修正できるので、まずは気楽に作成してみるのがおすすめです</li>
</ul>

<p style="margin: 0 0 20px 0;">
  <%= link_to "ストーリー作成", new_story_path, style: "display: inline-block; padding: 10px 16px; border: 2px solid #2563eb; border-radius: 12px; background: #2563eb; color: #ffffff; text-decoration: none; font-weight: bold;" %>
</p>

<% if @stories.any? %>
  <% @stories.each do |story| %>
    <div style="margin-bottom: 20px;">
      <%= link_to story_path(story), style: "display: block; text-decoration: none; color: inherit;" do %>
        <div style="padding: 16px; border: 2px solid #555555; border-radius: 16px; background: #1e1e1e;">
          <h2 style="color: #ddd6fe; text-decoration: none;"><%= story.title %></h2>

          <% if story.story_image&.image? %>
            <div style="margin: 8px 0;">
              <%= image_tag story.story_image.image.url, style: "width: 240px; height: 140px; object-fit: cover; display: block; border-radius: 12px;" %>
            </div>
          <% else %>
            <div style="width: 240px; height: 140px; margin: 8px 0; border: 2px solid #555555; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: #2a2a2a; color: #f5f5f5;">
              画像なし
            </div>
          <% end %>

          <p style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0; color: #f5f5f5; text-decoration: none;">
            <%= truncate(story.description.to_s, length: 78) %>
          </p>
        </div>
      <% end %>

      <div style="margin-top: 8px; color: #f5f5f5;">
        <span style="display: inline-block; margin-right: 12px;">
          <%= button_to "↑", move_up_story_path(story), method: :patch,
                        form: { style: "display:inline" },
                        style: "padding: 4px 10px; border: 1px solid #475569; border-radius: 6px; background: #334155; color: #ffffff; cursor: pointer;" %>
          <span style="color: #cbd5e1;">上に移動</span>
        </span>

        <span style="display: inline-block;">
          <%= button_to "↓", move_down_story_path(story), method: :patch,
                        form: { style: "display:inline" },
                        style: "padding: 4px 10px; border: 1px solid #475569; border-radius: 6px; background: #334155; color: #ffffff; cursor: pointer;" %>
          <span style="color: #cbd5e1;">下に移動</span>
        </span>
      </div>
    </div>
  <% end %>
<% else %>
  <p>まだストーリーがありません</p>
<% end %>
