<%= render "shared/breadcrumbs", items: @breadcrumbs %>

<p><%= link_to "戻る", story_path(@story) %></p>
<h1 style="color: #c4b5fd;">ストーリー編集</h1>
<%= render "form", story: @story %>

<p style="margin-top: 50px; color: #f87171; font-weight: bold;">※削除すると中のイベント / 詳細メモ / 要素 / 関連アイデアも消えます。</p>
<p>
  <%= link_to "このストーリーを削除",
              story_path(@story),
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？（中のイベント/詳細メモ/要素/関連アイデアも消えます）" },
              style: "display: inline-block; background: #dc2626; color: #ffffff; border: none; border-radius: 8px; padding: 12px 24px; font-weight: bold; text-decoration: none; cursor: pointer;" %>
</p>
