<%= render "shared/breadcrumbs", items: @breadcrumbs %>

<p><%= link_to "ストーリー一覧へ", stories_path, style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %></p>

<h1 style="color: #c4b5fd;">ストーリー詳細ページ</h1>

<ul style="margin: 8px 0 20px 20px; font-size: 17px; line-height: 1.8;">
  <li>ホームで作成したアイデアの中から、この作品に合うものを移動してみましょう。</li>
  <li>ストーリー本文はあとから整えていけるので、まずはアイデアを作成で気楽に素材を増やしてみましょう。</li>
  <li>良かったものや使いたいものができたら、ストーリー編集から本文に追加して、この作品の内容を少しずつ作っていけます。</li>
  <li>ストーリーがまとまってきたら、イベントを追加して、章ごとの物語の流れを時系列で整理していけます。</li>
</ul>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h1 style="color: #ddd6fe;"><%= @story.title %></h1>

<% if @story.story_image&.image? %>
  <div style="margin-top: 16px;">
    <%= image_tag @story.story_image.image.url, style: "max-width: 320px; height: auto; border-radius: 16px;" %>
  </div>
<% end %>

<h2 style="color: #ddd6fe;">説明</h2>
<% if @story.description.present? %>
  <div>
    <%= simple_format(@story.description) %>
  </div>
<% else %>
  <p>なし</p>
<% end %>

<p>
  <%= link_to "ストーリー編集", edit_story_path(@story), style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
  <span style="display: inline-block; margin-left: 24px;">
    作成日: <%= l @story.created_at.in_time_zone("Tokyo"), format: :short %>
  </span>
  <span style="display: inline-block; margin-left: 24px;">
    更新日（文字修正のみ）: <%= l (@story.text_updated_at || @story.created_at).in_time_zone("Tokyo"), format: :short %>
  </span>
</p>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<div style="margin: 24px 0; padding: 20px 0;">
  <h2 style="margin-top: 0; margin-bottom: 12px; color: #c4b5fd;">要素作成・整合性チェック</h2>

  <p style="margin: 0 0 16px 0; font-size: 16px; line-height: 1.8; color: #f5f5f5;">
    キャラクター・アイテム・設定は「要素」として登録して管理できます。<br>
    要素がどのイベントや詳細メモに登場するかは、整合性チェックで時系列に確認できます。
  </p>

  <p style="margin: 0;">
    <%= link_to "要素を管理する", story_story_elements_path(@story, from: "story"),
            style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f8f6b; border-radius: 12px; background: #5f8f6b; color: #ffffff; text-decoration: none; font-weight: bold; margin-right: 12px;" %>

    <%= link_to "整合性チェック", consistency_story_path(@story, from: "story"),
            style: "display: inline-block; padding: 10px 16px; border: 2px solid #ec4899; border-radius: 12px; background: #ec4899; color: #ffffff; text-decoration: none; font-weight: bold;" %>
  </p>
</div>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h2 style="color: #c4b5fd;">イベント（時系列）</h2>

<h4>このイベント欄は、整合性チェックの対象です。上から時系列の早い順として表示します。</h4>

<p>
  <%= link_to "イベント追加", new_story_story_event_path(@story),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #2563eb; border-radius: 12px; background: #2563eb; color: #ffffff; text-decoration: none; font-weight: bold;" %>
</p>

<% if @story_events.any? %>
  <% @story_events.each do |event| %>
    <div style="margin-bottom: 20px;">
      <%= link_to story_story_event_path(@story, event), style: "display: block; text-decoration: none; color: inherit;" do %>
        <div style="padding: 16px; border: 2px solid #555555; border-radius: 16px; background: #1e1e1e;">
          <h3 style="margin-top: 0; color: #ddd6fe; text-decoration: none;"><%= event.title %></h3>

          <% if event.story_event_image&.image? %>
            <div style="margin: 8px 0;">
              <%= image_tag event.story_event_image.image.url, style: "width: 240px; height: 140px; object-fit: cover; display: block; border-radius: 12px;" %>
            </div>
          <% else %>
            <div style="width: 240px; height: 140px; margin: 8px 0; border: 2px solid #555555; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: #2a2a2a; color: #f5f5f5;">
              画像なし
            </div>
          <% end %>

          <p style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 0; color: #f5f5f5; text-decoration: none;">
            <%= truncate(event.body.to_s, length: 78) %>
          </p>
        </div>
      <% end %>

      <div style="margin-top: 8px; color: #f5f5f5;">
        <span style="display: inline-block; margin-right: 12px;">
          <%= button_to "↑", move_up_story_story_event_path(@story, event),
                method: :patch,
                form: { style: "display:inline" },
                style: "padding: 4px 10px; border: 1px solid #475569; border-radius: 6px; background: #334155; color: #ffffff; cursor: pointer;" %>
          <span style="color: #cbd5e1;">上に移動</span>
        </span>

        <span style="display: inline-block;">
          <%= button_to "↓", move_down_story_story_event_path(@story, event),
                method: :patch,
                form: { style: "display:inline" },
                style: "padding: 4px 10px; border: 1px solid #475569; border-radius: 6px; background: #334155; color: #ffffff; cursor: pointer;" %>
          <span style="color: #cbd5e1;">下に移動</span>
        </span>
      </div>
    </div>
  <% end %>
<% else %>
  <p>まだイベントがありません</p>
<% end %>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h3 style="color: #c4b5fd;">新規アイデア</h3>

<p style="margin: 8px 0 20px 20px; font-size: 17px; line-height: 1.8;">
  作成した要素は、アイデア作成時に登場要素として選択できます。<br>
  アイデアと要素を結びつけておくと、検索で見つけやすくなり、あとから設定や登場場面を整理しやすくなります。
</p>

<p style="margin: 0 0 16px 0;">
  <%= link_to "アイデアを作成する", new_idea_path(return_to: request.fullpath, placeable_type: "Story", placeable_id: @story.id),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f8f6b; border-radius: 12px; background: #5f8f6b; color: #ffffff; text-decoration: none; font-weight: bold; margin-right: 12px;" %>
  <%= link_to "AIで作成する", random_words_pick_path(return_to: request.fullpath, placeable_type: "Story", placeable_id: @story.id),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f6ee6; border-radius: 12px; background: #5f6ee6; color: #ffffff; text-decoration: none; font-weight: bold;" %>
</p>

<% if @created_here_ideas.present? %>
  <ul>
    <% @created_here_ideas.each do |idea| %>
      <li>
        <%= link_to idea.title, idea_path(idea), style: "color: #ddd6fe; font-weight: bold; text-decoration: underline;" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだありません</p>
<% end %>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h3 style="color: #c4b5fd;">ここに移動したアイデア</h3>

<% if @moved_ideas.present? %>
  <ul>
    <% @moved_ideas.each do |idea| %>
      <li>
        <%= link_to idea.title, idea_path(idea), style: "color: #ddd6fe; font-weight: bold; text-decoration: underline;" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだありません</p>
<% end %>
