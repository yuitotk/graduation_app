<%= render "shared/breadcrumbs", items: @breadcrumbs %>

<p>
  <%= link_to "要素一覧へ戻る",
              story_story_elements_path(@story, breadcrumb_params),
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
</p>

<h1 style="color: #c4b5fd;">要素詳細</h1>

<hr>

<p style="font-size: 32px; font-weight: bold; margin: 0 0 16px 0; color: #ddd6fe;"><strong>名前：</strong><%= @story_element.name %></p>
<p style="color: #ddd6fe;"><strong>種別：</strong><%= { "character" => "キャラクター", "item" => "アイテム", "setting" => "設定" }[@story_element.kind] || @story_element.kind %></p>
<p style="color: #ddd6fe;"><strong>マーカー：</strong><%= @story_element.marker.presence || "なし" %></p>

<% if @story_element.story_element_image&.image? %>
  <div style="margin-top: 16px;">
    <%= image_tag @story_element.story_element_image.image.url, style: "max-width: 320px; height: auto; border-radius: 16px;" %>
  </div>
<% end %>

<h2 style="color: #ddd6fe;">メモ</h2>

<% if @story_element.memo.present? %>
  <div><%= simple_format(@story_element.memo) %></div>
<% else %>
  <p>なし</p>
<% end %>

<p>
  <%= link_to "編集",
              edit_story_story_element_path(@story, @story_element, breadcrumb_params),
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
  <span style="display: inline-block; margin-left: 24px;">
    作成日: <%= l @story_element.created_at.in_time_zone("Tokyo"), format: :short %>
  </span>
  <span style="display: inline-block; margin-left: 24px;">
    更新日（文字修正のみ）: <%= l (@story_element.text_updated_at || @story_element.created_at).in_time_zone("Tokyo"), format: :short %>
  </span>
</p>

<hr>

<h3 style="color: #c4b5fd;">新規アイデア</h3>

<p style="display: flex; gap: 12px; flex-wrap: wrap;">
  <%= link_to "新規作成",
              new_idea_path(
                return_to: request.fullpath,
                placeable_type: "StoryElement",
                placeable_id: @story_element.id
              ),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f8f6b; border-radius: 12px; background: #5f8f6b; color: #ffffff; text-decoration: none; font-weight: bold;" %>

  <%= link_to "AI作成",
              random_words_pick_path(
                return_to: request.fullpath,
                placeable_type: "StoryElement",
                placeable_id: @story_element.id
              ),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f6ee6; border-radius: 12px; background: #5f6ee6; color: #ffffff; text-decoration: none; font-weight: bold;" %>
</p>

<% if @created_here_ideas.present? %>
  <ul>
    <% @created_here_ideas.each do |idea| %>
      <li><%= link_to idea.title, idea_path(idea, breadcrumb_params), style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %></li>
    <% end %>
  </ul>
<% else %>
  <p>まだありません</p>
<% end %>

<hr>

<h3 style="color: #c4b5fd;">ここに移動したアイデア</h3>

<% if @moved_ideas.present? %>
  <ul>
    <% @moved_ideas.each do |idea| %>
      <li><%= link_to idea.title, idea_path(idea, breadcrumb_params), style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %></li>
    <% end %>
  </ul>
<% else %>
  <p>まだありません</p>
<% end %>
