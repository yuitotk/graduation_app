<%= render "shared/breadcrumbs", items: @breadcrumbs %>

<%
  story_event_for_back_link =
    if params[:story_event_id].present?
      @story.story_events.find_by(id: params[:story_event_id])
    end

  story_event_idea_for_back_link =
    if story_event_for_back_link.present? && params[:story_event_idea_id].present?
      story_event_for_back_link.story_event_ideas.find_by(id: params[:story_event_idea_id])
    end
%>

<% if params[:from] == "story_event_idea" && story_event_for_back_link.present? && story_event_idea_for_back_link.present? %>
  <%= link_to "詳細メモ詳細へ戻る",
              story_story_event_story_event_idea_path(@story, story_event_for_back_link, story_event_idea_for_back_link),
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
<% elsif params[:from] == "story_event" && story_event_for_back_link.present? %>
  <%= link_to "イベント詳細へ戻る",
              story_story_event_path(@story, story_event_for_back_link),
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
<% else %>
  <%= link_to "ストーリー詳細へ戻る",
              story_path(@story),
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
<% end %>

<h1 style="color: #c4b5fd;">要素一覧</h1>

<%= link_to "要素追加",
            new_story_story_element_path(@story, breadcrumb_params),
            style: "display: inline-block; margin-top: 8px; margin-bottom: 16px; padding: 10px 16px; background-color: #2563eb; color: #ffffff; font-weight: bold; text-decoration: none; border-radius: 8px;" %>

<% grouped_elements = @story_elements.group_by(&:kind) %>

<% [
  ["character", "キャラクター"],
  ["item", "アイテム"],
  ["setting", "設定"]
].each do |kind, title| %>
  <% next if grouped_elements[kind].blank? %>

  <h2 style="color: #c4b5fd;"><%= title %></h2>

  <ul>
    <% grouped_elements[kind].each do |e| %>
      <li>
        <%= link_to "#{e.marker.present? ? "#{e.marker}　" : ""}#{e.name}",
                    story_story_element_path(@story, e, breadcrumb_params),
                    style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
      </li>
    <% end %>
  </ul>
<% end %>
