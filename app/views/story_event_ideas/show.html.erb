<%= render "shared/breadcrumbs", items: @breadcrumbs %>

<%
  current_breadcrumb_params = {
    from: params[:from],
    story_event_id: params[:story_event_id],
    story_event_idea_id: params[:story_event_idea_id],
    page_type: params[:page_type],
    page_id: params[:page_id]
  }.compact.symbolize_keys

  story_event_idea_context_params = {
    from: "story_event_idea",
    story_event_id: @story_event.id,
    story_event_idea_id: @story_event_idea.id
  }

  original_story_event_idea =
    if params[:from] == "story_event_idea" && params[:story_event_idea_id].present?
      StoryEventIdea.includes(story_event: :story).find_by(id: params[:story_event_idea_id])
    end

  returning_to_other_story_event_idea =
    original_story_event_idea.present? &&
    original_story_event_idea.id.to_s != @story_event_idea.id.to_s

  back_path =
    if returning_to_other_story_event_idea
      story_story_event_story_event_idea_path(
        original_story_event_idea.story_event.story,
        original_story_event_idea.story_event,
        original_story_event_idea,
        {
          from: "story_event_idea",
          story_event_id: original_story_event_idea.story_event.id,
          story_event_idea_id: original_story_event_idea.id
        }
      )
    else
      story_story_event_path(@story, @story_event, current_breadcrumb_params)
    end

  back_label =
    if returning_to_other_story_event_idea
      "元の詳細メモへ戻る"
    else
      "イベント詳細へ戻る"
    end
%>

<p>
  <%= link_to back_label, back_path,
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
</p>

<h1 style="color: #c4b5fd;">詳細メモ詳細ページ</h1>

<p style="margin: 8px 0 20px 20px; font-size: 17px; line-height: 1.8;">
  ホームで作成したアイデアをこの詳細メモに移動して、内容ごとにまとめることができます。<br>
  イベント本体には書ききれない補足、別案、会話案、演出案などの記録がおすすめです。
</p>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h1 style="color: #ddd6fe;"><%= @story_event_idea.title %></h1>

<h4 style="color: #ddd6fe;">詳細メモの登場要素</h4>
<% if @story_event_idea.story_elements.any? %>
  <% grouped_elements = @story_event_idea.story_elements.group_by(&:kind) %>

  <div style="margin-top: 12px; border: 1px solid #555555; border-radius: 8px; padding: 16px; background: #1e1e1e;">
    <% [["character", "キャラクター"], ["item", "アイテム"], ["setting", "設定"]].each do |kind, kind_label| %>
      <% elements = grouped_elements[kind] || [] %>
      <% next if elements.blank? %>

      <details style="margin-bottom: 16px;">
        <summary style="cursor: pointer; background: #2a2a2a; border: 1px solid #555555; border-radius: 6px; padding: 10px 12px; font-weight: bold; color: #f5f5f5;">
          <%= kind_label %>（<%= elements.size %>）
        </summary>

        <div style="padding: 12px 8px 0 8px;">
          <% elements.each do |el| %>
            <div style="margin-bottom: 8px; color: #f5f5f5;">
              <%= story_element_short_label(el) %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% else %>
  <p>未設定</p>
<% end %>

<% if @story_event_idea.image.present? %>
  <h4 style="color: #ddd6fe;">画像</h4>
  <div style="margin-top: 16px;">
    <%= image_tag @story_event_idea.image.url, style: "max-width: 320px; height: auto; border-radius: 16px;" %>
  </div>
<% end %>

<h4 style="color: #ddd6fe;">説明</h4>
<div>
  <%= simple_format(@story_event_idea.memo) %>
</div>

<p>
  <%= link_to "詳細メモ編集",
              edit_story_story_event_story_event_idea_path(@story, @story_event, @story_event_idea),
              style: "color: #9ecbff; font-weight: bold; text-decoration: underline;" %>
  <span style="display: inline-block; margin-left: 24px;">
    作成日: <%= l @story_event_idea.created_at.in_time_zone("Tokyo"), format: :short %>
  </span>
  <span style="display: inline-block; margin-left: 24px;">
    更新日（文字修正のみ）: <%= l (@story_event_idea.text_updated_at || @story_event_idea.created_at).in_time_zone("Tokyo"), format: :short %>
  </span>
</p>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<div style="margin: 24px 0; padding: 20px 0;">
  <h2 style="margin-top: 0; margin-bottom: 12px; color: #c4b5fd;">要素作成・整合性チェック</h2>

  <p style="margin: 0 0 16px 0; font-size: 16px; line-height: 1.8; color: #f5f5f5;">
    キャラクター・アイテム・設定は「要素」として登録して管理できます。<br>
    要素がどのイベントや詳細メモに登場するかは、整合性チェックで時系列に確認できます。
  </p>

  <p style="margin: 0;">
    <%= link_to "要素を管理する",
                story_story_elements_path(
                  @story,
                  story_event_idea_context_params
                ),
                style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f8f6b; border-radius: 12px; background: #5f8f6b; color: #ffffff; text-decoration: none; font-weight: bold; margin-right: 12px;" %>

    <%= link_to "整合性チェック",
                consistency_story_path(
                  @story,
                  story_event_idea_context_params
                ),
                style: "display: inline-block; padding: 10px 16px; border: 2px solid #ec4899; border-radius: 12px; background: #ec4899; color: #ffffff; text-decoration: none; font-weight: bold;" %>
  </p>
</div>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h3 style="color: #c4b5fd;">新規アイデア</h3>

<p style="margin: 0 0 16px 0;">
  <%= link_to "新規作成",
              new_idea_path(
                return_to: request.fullpath,
                placeable_type: "StoryEventIdea",
                placeable_id: @story_event_idea.id
              ),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f8f6b; border-radius: 12px; background: #5f8f6b; color: #ffffff; text-decoration: none; font-weight: bold; margin-right: 12px;" %>

  <%= link_to "AI作成",
              random_words_pick_path(
                return_to: request.fullpath,
                placeable_type: "StoryEventIdea",
                placeable_id: @story_event_idea.id
              ),
              style: "display: inline-block; padding: 10px 16px; border: 2px solid #5f6ee6; border-radius: 12px; background: #5f6ee6; color: #ffffff; text-decoration: none; font-weight: bold;" %>
</p>

<% if @created_here_ideas.present? %>
  <ul>
    <% @created_here_ideas.each do |idea| %>
      <li>
        <%= link_to idea.title,
                    idea_path(
                      idea,
                      from: "story_event_idea",
                      story_event_id: @story_event.id,
                      story_event_idea_id: @story_event_idea.id
                    ),
                    style: "color: #ddd6fe; font-weight: bold; text-decoration: underline;" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだありません</p>
<% end %>

<hr style="border: none; border-top: 1px solid #444444; margin: 20px 0;">

<h3 style="color: #c4b5fd;">ここに移動したアイデア</h3>

<% if @moved_ideas.present? %>
  <ul>
    <% @moved_ideas.each do |idea| %>
      <li>
        <%= link_to idea.title,
                    idea_path(
                      idea,
                      from: "story_event_idea",
                      story_event_id: @story_event.id,
                      story_event_idea_id: @story_event_idea.id
                    ),
                    style: "color: #ddd6fe; font-weight: bold; text-decoration: underline;" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>まだありません</p>
<% end %>
