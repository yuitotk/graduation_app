<div style="
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40px 20px;
  box-sizing: border-box;
">
  <div style="
    max-width: 900px;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.45);
    padding: 32px 24px;
    border-radius: 16px;
    color: #ffffff;
  ">
    <h1>トップページ</h1>

    <p>このアプリの説明</p>

    <% if logged_in? %>
      <p>ログイン中</p>
      <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete } %>
    <% else %>
      <ul style="list-style: none; padding-left: 0; margin: 0;">
        <li><%= link_to "ログインへ", login_path %></li>
        <li><%= link_to "登録へ", signup_path %></li>
      </ul>
    <% end %>
  </div>
</div>
