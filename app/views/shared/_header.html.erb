<header>
  <style>
    .header-mobile-break {
      display: inline;
    }

    .header-mobile-break-prefix {
      display: inline;
    }

    @media (max-width: 767px) {
      .header-search-form {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
      }

      .header-search-input {
        width: calc(100% - 120px) !important;
        min-width: 0;
        box-sizing: border-box;
      }

      .header-search-scope {
        width: 112px;
        flex: 0 0 112px;
        box-sizing: border-box;
      }

      .header-search-within-story {
        display: block;
        width: 100%;
      }

      .header-search-within-story label {
        margin-left: 0 !important;
      }

      .header-search-element-filter {
        display: block !important;
        width: 100%;
        margin-left: 0 !important;
      }

      #story_element_select {
        width: 300px;
        box-sizing: border-box;
      }

      .header-search-submit-wrap {
        display: block;
        width: 100%;
      }

      .header-search-autocomplete-list {
        width: 100% !important;
        box-sizing: border-box;
      }

      .header-mobile-break {
        display: block;
        margin-top: 4px;
      }

      .header-mobile-break-prefix {
        display: none;
      }
    }
  </style>

  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <% logo_path = logged_in? ? ideas_path : root_path %>
      <%= link_to "ロゴ", logo_path %>
    </div>

    <% if logged_in? %>
      <%= button_to "ログアウト", logout_path, method: :delete,
                    form: { data: { turbo: false }, style: "display: inline-block; margin: 0;" },
                    style: "padding: 8px 14px; border: 1px solid #333; border-radius: 6px; background: white; color: #333; cursor: pointer;" %>
    <% else %>
      <div style="display: flex; gap: 8px;">
        <%= link_to "ログイン", login_path,
                    style: "display: inline-block; padding: 8px 14px; border: 1px solid #333; border-radius: 6px; text-decoration: none; color: #333;" %>

        <%= link_to "新規登録", signup_path,
                    style: "display: inline-block; padding: 8px 14px; border: 1px solid #333; border-radius: 6px; text-decoration: none; color: #333;" %>
      </div>
    <% end %>
  </div>

  <hr>

  <% if logged_in? %>
    <%= link_to "使い方・ヘルプ", help_path %> |
    <%= link_to "お問い合わせ", new_inquiry_path %>
    <span class="header-mobile-break">
      <span class="header-mobile-break-prefix"> | </span>
      <%= link_to "利用規約", terms_path %> |
      <%= link_to "プライバシーポリシー", privacy_path %>
    </span>

    <hr>

    <!-- 検索UI -->
    <%= form_with url: search_path, method: :get, local: true,
                  class: "header-search-form",
                  data: { controller: "search-autocomplete" } do %>

      <%= text_field_tag :q, params[:q],
                         placeholder: "検索",
                         class: "header-search-input",
                         style: "width: 220px;",
                         data: { "search-autocomplete-target": "input",
                                 action: "input->search-autocomplete#onInput" } %>

      <% hide_within_story_ui =
           (controller_name == "ideas" && action_name == "index") ||
           (controller_name == "ideas" && action_name == "new" && params[:placeable_type].blank? && params[:placeable_id].blank?) ||
           (controller_name == "stories" && %w[index new].include?(action_name)) ||
           (controller_name == "random_words" && params[:placeable_type].blank? && params[:placeable_id].blank?) %>

      <% in_story_ui = search_in_story? && !hide_within_story_ui %>

      <% scope_options =
           if in_story_ui
             [
               ["すべて", "all"],
               ["ストーリー内", "story"],
               ["イベント内", "event"],
               ["要素内", "element"]
             ]
           else
             [
               ["すべて", "all"],
               ["ホーム未所属", "home"],
               ["ストーリー内", "story"],
               ["イベント内", "event"],
               ["要素内", "element"]
             ]
           end %>

      <% selected_scope = params[:scope].presence || "all" %>
      <% selected_scope = "all" if in_story_ui && selected_scope == "home" %>

      <%= select_tag :scope,
                     options_for_select(scope_options, selected_scope),
                     id: "search_scope_select",
                     class: "header-search-scope",
                     data: { "search-autocomplete-target": "scope" } %>

      <% header_story =
           begin
             if controller_name == "stories" && %w[show consistency].include?(action_name) && params[:id].present?
               current_user.stories.find_by(id: params[:id])
             elsif params[:story_id].present?
               current_user.stories.find_by(id: params[:story_id])
             elsif controller_name == "story_events" && action_name == "show" && params[:id].present?
               StoryEvent.joins(:story).where(stories: { user_id: current_user.id }).find_by(id: params[:id])&.story
             elsif controller_name == "story_elements" && action_name == "show" && params[:id].present?
               StoryElement.joins(:story).where(stories: { user_id: current_user.id }).find_by(id: params[:id])&.story
             elsif params[:placeable_type].present? && params[:placeable_id].present?
               case params[:placeable_type].to_s
               when "Story"
                 current_user.stories.find_by(id: params[:placeable_id])
               when "StoryEvent"
                 StoryEvent.joins(:story).where(stories: { user_id: current_user.id }).find_by(id: params[:placeable_id])&.story
               when "StoryElement"
                 StoryElement.joins(:story).where(stories: { user_id: current_user.id }).find_by(id: params[:placeable_id])&.story
               end
             elsif controller_name == "search" && action_name == "index"
               params[:story_id].present? ? current_search_story : nil
             else
               nil
             end
           end %>

      <% allow_within_story_toggle =
           (
             (controller_name == "search" && action_name == "index") ||
             (controller_name == "stories" && action_name == "show") ||
             (controller_name == "stories" && action_name == "consistency") ||
             (controller_name == "story_events" && action_name == "show") ||
             (controller_name == "story_events" && %w[new edit].include?(action_name)) ||
             (controller_name == "story_event_ideas" && %w[new edit].include?(action_name)) ||
             (controller_name == "story_elements" && action_name == "show") ||
             (controller_name == "story_elements" && action_name == "index") ||
             (controller_name == "story_elements" && %w[new edit].include?(action_name)) ||
             (controller_name == "ideas" && action_name == "new" &&
               params[:placeable_type].present? && params[:placeable_id].present?) ||
             (controller_name == "ideas" && %w[show edit update].include?(action_name)) ||
             (controller_name == "random_words" && action_name == "pick" &&
               params[:placeable_type].present? && params[:placeable_id].present?)
           ) && !hide_within_story_ui %>

      <% if header_story.blank? && allow_within_story_toggle %>
        <% unless controller_name == "search" && action_name == "index" && params[:story_id].blank? %>
          <% header_story = current_search_story %>
        <% end %>
      <% end %>

      <% if header_story.present? && allow_within_story_toggle %>
        <span class="header-search-within-story">
          <label style="margin-left: 8px;">
            <%= check_box_tag :within_story, "1", in_story_ui,
                              id: "within_story_checkbox",
                              data: { "search-autocomplete-target": "withinStory" } %>
            この作品内（<%= header_story.title %>）
          </label>

          <%= hidden_field_tag :story_id, header_story.id,
                               data: { "search-autocomplete-target": "storyId" } %>
        </span>
      <% end %>

      <% if header_story.present? && allow_within_story_toggle %>
        <% story_element_options =
             [["（要素で絞り込み：なし）", ""]] +
             header_story.story_elements
                        .order(:kind, :name, :id)
                        .map { |e|
                          label = [e.marker.presence, e.name.presence, e.kind.presence].compact.join(" ")
                          [label, e.id]
                        } %>

        <span id="story_element_filter_wrapper"
              class="header-search-element-filter"
              style="margin-left: 8px; display: <%= in_story_ui ? 'inline-block' : 'none' %>;">
          <%= select_tag :story_element_id,
                         options_for_select(story_element_options, params[:story_element_id].to_s),
                         id: "story_element_select",
                         data: { "search-autocomplete-target": "storyElement" } %>
        </span>
      <% end %>

      <% return_to_value =
           if controller_name == "search" && action_name == "index"
             session[:search_return_to].presence || params[:return_to].presence
           else
             request.fullpath
           end %>
      <%= hidden_field_tag :return_to, return_to_value %>

      <span class="header-search-submit-wrap">
        <%= submit_tag "検索" %>
      </span>

      <ul data-search-autocomplete-target="list"
          class="header-search-autocomplete-list"
          hidden
          style="list-style:none; margin:4px 0 0; padding:6px; border:1px solid #ccc; width: 360px;">
      </ul>

      <script>
        const setupSearchHeader = () => {
          const checkbox = document.getElementById("within_story_checkbox");
          const select = document.getElementById("search_scope_select");
          if (!checkbox || !select) return;

          const elementWrap = document.getElementById("story_element_filter_wrapper");
          const elementSelect = document.getElementById("story_element_select");

          if (checkbox.dataset.bound === "1") return;
          checkbox.dataset.bound = "1";

          const ensureHomeOption = () => {
            const exists = Array.from(select.options).some((o) => o.value === "home");
            if (exists) return;

            const opt = document.createElement("option");
            opt.value = "home";
            opt.textContent = "ホーム未所属";

            const allOpt = Array.from(select.options).find((o) => o.value === "all");
            if (allOpt && allOpt.nextSibling) {
              select.insertBefore(opt, allOpt.nextSibling);
            } else {
              select.appendChild(opt);
            }
          };

          const removeHomeOption = () => {
            Array.from(select.options).forEach((o) => {
              if (o.value === "home") o.remove();
            });
          };

          const sync = () => {
            if (checkbox.checked) {
              if (select.value === "home") select.value = "all";
              removeHomeOption();

              if (elementWrap) elementWrap.style.display = "inline-block";
            } else {
              ensureHomeOption();

              if (elementSelect) elementSelect.value = "";
              if (elementWrap) elementWrap.style.display = "none";
            }
          };

          checkbox.addEventListener("change", sync);
          sync();
        };

        document.addEventListener("DOMContentLoaded", setupSearchHeader);
        document.addEventListener("turbo:load", setupSearchHeader);
      </script>
    <% end %>
  <% else %>
    <%= link_to "使い方・ヘルプ", help_path %> |
    <%= link_to "利用規約", terms_path %>
    <span class="header-mobile-break">
      <span class="header-mobile-break-prefix"> | </span>
      <%= link_to "プライバシーポリシー", privacy_path %>
    </span>
  <% end %>
</header>
